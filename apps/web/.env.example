# --- AI (job parsing + email classification) ---------------------------------
# Create a key at https://platform.claude.com — used server-side only.
ANTHROPIC_API_KEY=
# Model used for parsing/classification. Haiku is fast and costs fractions of
# a cent per job/email. Any current Claude model id works here.
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Gmail monitoring ---------------------------------------------------------
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth Client ID
# Type: "Web application". Authorized redirect URI:
#   http://localhost:3000/api/gmail/callback   (plus your deployed URL later)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL of this app (used to build the OAuth redirect URI).
APP_URL=http://localhost:3000

# --- Storage ------------------------------------------------------------------
# SQLite file location. Defaults to ./data/jobtracker.db inside apps/web.
# DATABASE_PATH=

# --- Scheduled sync (hosted deployments) ---------------------------------------
# Random string; Vercel Cron sends it as a Bearer token to /api/gmail/sync.
# CRON_SECRET=
