{
  "name": "JobTrackr",
  "short_name": "JobTrackr",
  "description": "AI-powered job application tracker",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#16241E",
  "theme_color": "#16241E",
  "icons": [
    { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png" }
  ],
  "share_target": {
    "action": "/capture",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
